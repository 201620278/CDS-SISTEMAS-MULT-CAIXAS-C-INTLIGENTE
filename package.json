{
  "name": "cds-sistemas",
  "version": "1.0.3",
  "description": "Sistema de gestão para mercado",
  "author": "CDS Sistemas",
  "main": "electron.js",
  "scripts": {
    "start": ".\\node_modules\\.bin\\electron.cmd .",
    "start:local": ".\\node_modules\\.bin\\electron.cmd . --cds-forcar-local",
    "recuperar:local": "node scripts/criar-flag-modo-local.js",
    "start:recuperar": "node scripts/criar-flag-modo-local.js && .\\node_modules\\.bin\\electron.cmd .",
    "start:pdv": ".\\node_modules\\.bin\\electron.cmd electron-pdv.js",
    "start:erp": ".\\node_modules\\.bin\\electron.cmd electron-erp.js",
    "build": "node scripts/prebuild-electron.js && electron-builder",
    "build:erp": "electron-builder --config electron-builder-erp.json",
    "build:pdv": "electron-builder --config electron-builder-pdv.json",
    "build:all": "node scripts/prebuild-electron.js && electron-builder --config electron-builder-erp.json && electron-builder --config electron-builder-pdv.json",
    "test:integration": "node tests/integration/flow_test.js",
    "test:conversao-unidades": "node tests/motor-conversao-unidades/motor-conversao-unidades.test.js",
    "test:fracionado": "npm run test:conversao-unidades",
    "test:tef-fluxo": "node tests/tef/tef-fluxo-pagamento.test.js",
    "test:tef-fluxo-api": "node scripts/test-tef-fluxo-api.js",
    "test:tef": "node tests/tef/tef-fluxo-pagamento.test.js && node scripts/test-tef-fluxo-api.js",
    "test:equipamentos-drivers": "node tests/motor-equipamentos/drivers-framework.test.js",
    "test:equipamentos-toledo-prix4": "node tests/motor-equipamentos/toledo-prix4-driver.test.js",
    "test:equipamentos-toledo-tcp": "node tests/motor-equipamentos/toledo-prix4-tcp.test.js",
    "test:equipamentos-contracts": "node tests/motor-equipamentos/contracts-framework.test.js",
    "test:equipamentos-tcp": "node tests/motor-equipamentos/tcp-connection.test.js",
    "test:equipamentos-service": "node tests/motor-equipamentos/equipamentos-service.test.js",
    "test:equipamentos-sync": "node tests/motor-equipamentos/sync-framework.test.js",
    "test:equipamentos-transport": "node tests/motor-equipamentos/transport-framework.test.js",
    "test:equipamentos-toledo-protocol": "node tests/motor-equipamentos/toledo-prix4-protocol.test.js",
    "test:equipamentos-laboratorio": "node tests/motor-equipamentos/laboratorio-sprint12.test.js",
    "test:equipamentos-engenharia-reversa": "node tests/motor-equipamentos/engenharia-reversa-sprint13.test.js",
    "test:equipamentos": "npm run test:equipamentos-contracts && npm run test:equipamentos-drivers && npm run test:equipamentos-transport && npm run test:equipamentos-tcp && npm run test:equipamentos-service && npm run test:equipamentos-sync && npm run test:equipamentos-toledo-protocol && npm run test:equipamentos-toledo-tcp && npm run test:equipamentos-toledo-prix4 && npm run test:equipamentos-laboratorio && npm run test:equipamentos-engenharia-reversa"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "axios": "^1.15.0",
    "archiver": "^5.3.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "sqlite3": "^5.1.6",
    "xml-crypto": "^6.1.2",
    "xml2js": "^0.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "22.3.27",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.cdssistemas.cds",
    "productName": "CDS Sistemas - PDV",
    "copyright": "Copyright © 2026 CDS Sistemas - Cicero Diego",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!dist-*/**",
      "!release/**",
      "!out/**",
      "!tests/**",
      "!scripts/**",
      "!dados/**",
      "!**/.git/**",
      "!**/.cursor/**",
      "!**/*.md",
      "!**/{.DS_Store,Thumbs.db,Desktop.ini}",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/.bin/**"
    ],
    "asarUnpack": [
      "**/node_modules/sqlite3/**",
      "**/node_modules/usb/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signtoolOptions": {
        "publisherName": "CDS Sistemas"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CDS Sistemas",
      "artifactName": "CDS-Sistemas-Setup-${version}.${ext}",
      "uninstallDisplayName": "CDS Sistemas"
    }
  }
}
